# ============================================================
# ChatBI Agent — 环境变量配置模板
# ============================================================
# 使用方法：复制本文件为 .env 并填入真实值
#   cp .env.example .env
#
# ⚠️ 请勿将 .env 文件提交到 Git！

# ============================================================
# PostgreSQL 数据库
# ============================================================
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DB_DSN=postgresql://postgres:your_password@localhost:5432/chatbi_data

# 连接池配置（可选，有默认值）
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10
DB_COMMAND_TIMEOUT=30

# ============================================================
# LLM 大语言模型（兼容 OpenAI 协议）
# ============================================================
# 以阿里云 DashScope（通义千问）为例：
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-max

# 其他模型提供商（按需配置，取消注释并填入）：
# --- DeepSeek ---
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# --- OpenAI ---
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ============================================================
# Embedding 模型（可选，有默认值）
# ============================================================
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DEVICE=cpu
# EMBEDDING_BATCH_SIZE=32

# ============================================================
# HuggingFace 镜像（国内加速，可选）
# ============================================================
# HF_ENDPOINT=https://hf-mirror.com

# ============================================================
# 缓存（可选，默认使用本地磁盘缓存）
# ============================================================
# CACHE_BACKEND=disk
# REDIS_DSN=redis://localhost:6379/0

# ============================================================
# 前端跨域（可选，有默认值）
# ============================================================
# CORS_ORIGINS=["http://localhost:3000"]

# ============================================================
# 前端 API 地址（可选，默认 http://localhost:8004/api）
# ============================================================
# NEXT_PUBLIC_API_URL=http://localhost:8004/api
